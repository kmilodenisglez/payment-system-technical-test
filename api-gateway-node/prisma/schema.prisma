// This is your Prisma schema file.
// Learn more: https://www.prisma.io/docs/orm/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cards    Card[]
  payments Payment[]

  @@map("users")
  @@index([email]) // Optimizes lookups during authentication/registration
}

// ─── Cards ────────────────────────────────────────────────────────────────────
// PCI-DSS note: we NEVER store the real card number (PAN).
// Only the last 4 digits and a randomly generated fake_token are persisted.

model Card {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  holderName String   @map("holder_name") @db.VarChar(120)
  last4      String   @map("last4") @db.Char(4)
  brand      String   @db.VarChar(50) // e.g. "VISA", "MASTERCARD"
  fakeToken  String   @unique @map("fake_token") @db.VarChar(100)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@map("cards")
  @@index([userId]) // Optimizes wallet loading for users
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  cardId        String        @map("card_id") @db.Uuid
  amount        Decimal       @db.Decimal(12, 2) // Increased to 12 for high-inflation currencies
  currency      String        @default("USD") @db.Char(3) // ISO 4217 standard (e.g. USD, EUR, COP)
  status        PaymentStatus @default(PENDING) // Enum ensures integrity at DB level
  transactionId String?       @unique @map("transaction_id") @db.VarChar(100) // Prevents duplicate charges
  bankMessage   String?       @map("bank_message") @db.VarChar(255)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  card Card @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@map("payments")
  // Critical indexes for reporting, history queries, and bank reconciliation
  @@index([userId, createdAt])
  @@index([transactionId])
  @@index([status])
}
