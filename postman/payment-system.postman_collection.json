{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Payment System API",
    "description": "Complete test suite for the Payment System API Gateway.\n\n**Flow:**\n1. Create a user → saves `userId` automatically\n2. Register a card → saves `cardId` automatically\n3. Create a payment → calls the Python processor (80% approved)\n4. Check payment history\n\n**Base URL:** `http://localhost:3000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "userId",  "value": "",                     "type": "string" },
    { "key": "cardId",  "value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('userId', body.id);",
                  "  pm.test('User created', () => pm.response.to.have.status(201));",
                  "  pm.test('Has UUID', () => pm.expect(body.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "Register Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('cardId', body.id);",
                  "  pm.test('Card registered', () => pm.response.to.have.status(201));",
                  "  pm.test('Has fakeToken', () => pm.expect(body.fakeToken).to.match(/^tok_/));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"holderName\": \"Alice Johnson\",\n  \"last4\": \"4242\",\n  \"brand\": \"Visa\",\n  \"expiresAt\": \"2027-12-31\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/cards", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cards"] }
          },
          "response": []
        },
        {
          "name": "List Cards by User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cards?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cards"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "Get Card by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cards/{{cardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cards", "{{cardId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Status is approved or rejected', () => {",
                  "  pm.expect(['approved', 'rejected']).to.include(body.status);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"cardId\": \"{{cardId}}\",\n  \"amount\": 120.50\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments"] }
          },
          "response": []
        },
        {
          "name": "List Payment History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Create User — Duplicate Email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Duplicate\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        },
        {
          "name": "Create Payment — Invalid Amount (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"cardId\": \"{{cardId}}\",\n  \"amount\": -50\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments"] }
          },
          "response": []
        },
        {
          "name": "Get User — Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
